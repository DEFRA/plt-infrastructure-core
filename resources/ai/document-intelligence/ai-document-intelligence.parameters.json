{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "aiDocumentIntelligence": {
            "value": {
                "name": "#{{ documentIntelligenceResourceName }}",
                "sku": "#{{ documentIntelligenceSku }}",
                "customSubDomainName": "#{{ documentIntelligenceResourceName }}",
                "disableLocalAuth": false
            }    
        },
        "vnet": {
            "value": {
              "name": "#{{ virtualNetworkName }}",
              "resourceGroup": "#{{ virtualNetworkResourceGroup }}",
              "subnetPrivateEndpoints": "#{{ pepSubnet }}"
            }
        },
        "subType": {
            "value": "#{{ subType }}"
        }
    }
}
