{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "storageAccount": {
            "value": {
                "name": "#{{ infraResourceNamePrefix }}#{{ nc_resource_storageaccount }}#{{ environmentId }}#{{ regionCode }}01",
                "privateEndpointName": "#{{ infraResourceNamePrefix }}#{{ nc_resource_privateendpoint }}#{{ environmentId }}#{{ regionCode }}05",
                "skuName": "Standard_ZRS"
            }    
        },
        "vnet": {
            "value": {
              "name": "#{{ virtualNetworkName }}",
              "resourceGroup": "#{{ virtualNetworkResourceGroup }}",
              "subnetPrivateEndpoints": "#{{ networkResourceNamePrefix }}#{{ nc_resource_subnet }}#{{ environmentId }}#{{ regionCode }}98"
            }
        },
"subType": {
            "value": "#{{ subType }}"
          },
        "location": {
            "value": "#{{ location }}"
        },
        "resourceLockEnabled": {
            "value": #{{ resourceLockEnabled }}
        }
    }
}