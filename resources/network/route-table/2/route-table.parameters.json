{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "routeTable": {
      "value": {
        "name": "#{{ routeTableName }}",
        "virtualApplicanceIp": "#{{ firewallVirtualApplianceIp }}"
      }
    },
    "routeTableSuffix": {
      "value": "02"
    },
    "routes": {
      "value": [
        {
          "name": "Default",
          "properties": {
            "addressPrefix": "0.0.0.0/0",
            "nextHopType": "VirtualAppliance",
            "nextHopIpAddress": "#{{ firewallVirtualApplianceIp }}"
          }
        }
      ]
    },
    "location": {
      "value": "#{{ location }}"
    },
    "subType": {
      "value": "#{{ subType }}"
    },
    "resourceLockEnabled": {
      "value": "#{{ resourceLockEnabled }}"
    }
  }
}
