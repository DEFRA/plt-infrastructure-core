{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "name": {
      "value": "#{{ virtualNetworkName }}"
    },
    "addressPrefixes": {
      "value": #{{ noescape(addressPrefixes) }}
    },
    "dnsServers": {
      "value": #{{ noescape(dnsServers) }}
    },
    "subnets": {
      "value": [
        {
          "name": "#{{ subnet1Name }}",
          "addressPrefix": "#{{ subnet1AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [
            {
              "name": "aciDelegation",
              "properties": { "serviceName": "Microsoft.ContainerInstance/containerGroups" }
            }
          ],
          "routeTable": { "id": "#{{ subnet1RouteTableResourceId }}" }
        },
        {
          "name": "#{{ subnet2Name }}",
          "addressPrefix": "#{{ subnet2AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [],
          "routeTable": { "id": "#{{ subnet2RouteTableResourceId }}" }
        },
        {
          "name": "#{{ subnet3Name }}",
          "addressPrefix": "#{{ subnet3AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [],
          "routeTable": { "id": "#{{ subnet3RouteTableResourceId }}" }
        },
        {
          "name": "#{{ subnet4Name }}",
          "addressPrefix": "#{{ subnet4AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [],
          "routeTable": { "id": "#{{ subnet4RouteTableResourceId }}" }
        },
        {
          "name": "#{{ subnet5Name }}",
          "addressPrefix": "#{{ subnet5AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [],
          "routeTable": { "id": "#{{ subnet5RouteTableResourceId }}" }
        },
        {
          "name": "#{{ subnet6Name }}",
          "addressPrefix": "#{{ subnet6AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [],
          "routeTable": { "id": "#{{ subnet6RouteTableResourceId }}" }
        },
        {
          "name": "#{{ subnet7Name }}",
          "addressPrefix": "#{{ subnet7AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [],
          "routeTable": { "id": "#{{ subnet7RouteTableResourceId }}" 
        }
        }
      ]
    },
    "location": {
      "value": "#{{ location }}"
    },
    "subType": {
      "value": "#{{ subType }}"
    },
    "resourceLockEnabled": {
      "value": "#{{ resourceLockEnabled }}"
    },
    "networkJoinGroupObjectId": {
      "value": "#{{ networkJoinGroupObjectId }}"
    }
  }
}
