{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "name": {
      "value": "#{{ virtualNetworkName }}"
    },
    "addressPrefixes": {
      "value": #{{ noescape(addressPrefixes) }}
    },
    "dnsServers": {
      "value": #{{ noescape(dnsServers) }}
    },
    "routeTableName": {
      "value": "#{{ routeTableName }}"
    },
    "svc": {
      "value": "#{{ serviceCode }}"
    },
    "deploymentEnvInstance": {
      "value": "#{{ deploymentEnvInstance }}"
    },
    "regionCode": {
      "value": "#{{ regionCode }}"
    },
    "subnets": {
      "value": [
        {
          "addressPrefix": "#{{ subnet1AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [
            {
              "name": "aciDelegation",
              "properties": { "serviceName": "Microsoft.ContainerInstance/containerGroups" }
            }
          ],
          "routeTable": { "routeTableNumber": "#{{ subnet1RouteTable }}" }
        },
        {
          "addressPrefix": "#{{ subnet2AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [],
          "routeTable": { "routeTableNumber": "#{{ subnet2RouteTable }}" }
        },
        {
          "addressPrefix": "#{{ subnet3AddressPrefix }}",
          "serviceEndpoints": [],
          "privateEndpointNetworkPolicies": "Enabled",
          "privateLinkServiceNetworkPolicies": "Enabled",
          "delegations": [],
          "routeTable": { "routeTableNumber": "#{{ subnet3RouteTable }}" }
        }
      ]
    },
    "location": {
      "value": "#{{ location }}"
    },
    "subType": {
      "value": "#{{ subType }}"
    },
    "resourceLockEnabled": {
      "value": "#{{ resourceLockEnabled }}"
    },
    "networkJoinGroupObjectId": {
      "value": "#{{ networkJoinGroupObjectId }}"
    }
  }
}
