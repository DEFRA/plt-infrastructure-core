{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vnet": {
      "value": "{\"name\":\"{{ vnetNameSpoke }}\",\"addressPrefixes\":[\"{{ addressPrefixesSpoke }}\"],\"dnsServers\":[\"{{ dnsServersSpoke }}\"]}"
    },
    
    "subnets": {
      "value": "{{ subnets }}"
    },
    "location": {
      "value": "#{{ location }}"
    },
    "environment": {
      "value": "#{{ environment }}"
    },
    "resourceLockEnabled": {
      "value": "#{{ resourceLockEnabled }}"
    }
  }
}